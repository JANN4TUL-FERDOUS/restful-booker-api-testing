    {
      "name": "Booking",
      "item": [
        {
          "name": "Create Booking",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const response = pm.response.json();",
                  "",
                  "pm.test(\"Status code is 200\", function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test(\"Booking ID is returned\", function () {",
                  "    pm.expect(response.bookingid).to.exist;",
                  "});",
                  "",
                  "pm.test(\"First name is correct\", function () {",
                  "    pm.expect(response.booking.firstname).to.eql(\"John\");",
                  "});",
                  "",
                  "pm.test(\"Last name is correct\", function () {",
                  "    pm.expect(response.booking.lastname).to.eql(\"Doe\");",
                  "});",
                  "",
                  "pm.test(\"Total price is correct\", function () {",
                  "    pm.expect(response.booking.totalprice).to.eql(120);",
                  "});",
                  "",
                  "pm.test(\"Deposit status is correct\", function () {",
                  "    pm.expect(response.booking.depositpaid).to.eql(true);",
                  "});",
                  "",
                  "pm.test(\"Response time is less than 1000 ms\", function () {",
                  "    pm.expect(pm.response.responseTime).to.be.below(1000);",
                  "});",
                  "",
                  "pm.environment.set(\"bookingid\", response.bookingid);"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\r\n    \"firstname\": \"John\",\r\n    \"lastname\": \"Doe\",\r\n    \"totalprice\": 120,\r\n    \"depositpaid\": true,\r\n    \"bookingdates\": {\r\n        \"checkin\": \"2025-07-15\",\r\n        \"checkout\": \"2025-07-20\"\r\n    },\r\n    \"additionalneeds\": \"Breakfast\"\r\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{base_url}}/booking",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "booking"
              ]
            }
          },
          "response": []
