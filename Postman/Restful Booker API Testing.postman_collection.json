        {
          "name": "Get Booking by ID",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const response = pm.response.json();\r",
                  "\r",
                  "pm.test(\"Status code is 200\", function () {\r",
                  "    pm.response.to.have.status(200);\r",
                  "});\r",
                  "\r",
                  "pm.test(\"First name is correct\", function () {\r",
                  "    pm.expect(response.firstname).to.eql(\"John\");\r",
                  "});\r",
                  "\r",
                  "pm.test(\"Last name is correct\", function () {\r",
                  "    pm.expect(response.lastname).to.eql(\"Doe\");\r",
                  "});\r",
                  "\r",
                  "pm.test(\"Total price is correct\", function () {\r",
                  "    pm.expect(response.totalprice).to.eql(120);\r",
                  "});\r",
                  "\r",
                  "pm.test(\"Deposit status is true\", function () {\r",
                  "    pm.expect(response.depositpaid).to.be.true;\r",
                  "});\r",
                  "\r",
                  "pm.test(\"Check-in date is correct\", function () {\r",
                  "    pm.expect(response.bookingdates.checkin).to.eql(\"2025-07-15\");\r",
                  "});\r",
                  "\r",
                  "pm.test(\"Check-out date is correct\", function () {\r",
                  "    pm.expect(response.bookingdates.checkout).to.eql(\"2025-07-20\");\r",
                  "});\r",
                  "\r",
                  "pm.test(\"Additional needs are correct\", function () {\r",
                  "    pm.expect(response.additionalneeds).to.eql(\"Breakfast\");\r",
                  "});\r",
                  "\r",
                  "pm.test(\"Booking response contains all required properties\", function () {\r",
                  "    pm.expect(response).to.have.property(\"firstname\");\r",
                  "    pm.expect(response).to.have.property(\"lastname\");\r",
                  "    pm.expect(response).to.have.property(\"totalprice\");\r",
                  "    pm.expect(response).to.have.property(\"depositpaid\");\r",
                  "    pm.expect(response).to.have.property(\"bookingdates\");\r",
                  "});\r",
                  "\r",
                  "pm.test(\"Response time is below 1000 ms\", function () {\r",
                  "    pm.expect(pm.response.responseTime).to.be.below(1000);\r",
                  "});"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            }
