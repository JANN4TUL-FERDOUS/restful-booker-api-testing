        {
          "name": "Get Booking IDs",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status code is 200\", function () {\r",
                  "    pm.response.to.have.status(200);\r",
                  "});\r",
                  "\r",
                  "const response = pm.response.json();\r",
                  "\r",
                  "pm.test(\"Response is an array\", function () {\r",
                  "    pm.expect(response).to.be.an(\"array\");\r",
                  "});\r",
                  "\r",
                  "pm.test(\"At least one booking is returned\", function () {\r",
                  "    pm.expect(response.length).to.be.greaterThan(0);\r",
                  "});\r",
                  "\r",
                  "pm.test(\"Each booking contains a booking ID\", function () {\r",
                  "    response.forEach(function(item) {\r",
                  "        pm.expect(item).to.have.property(\"bookingid\");\r",
                  "    });\r",
                  "});\r",
                  "\r",
                  "pm.test(\"Response time is below 1000 ms\", function () {\r",
                  "    pm.expect(pm.response.responseTime).to.be.below(1000);\r",
                  "});"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            }
