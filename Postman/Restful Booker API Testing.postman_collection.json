    {
      "name": "Authentication",
      "item": [
        {
          "name": "Generate Auth Token",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const response = pm.response.json();\r",
                  "\r",
                  "pm.test(\"Status code is 200\", function () {\r",
                  "    pm.response.to.have.status(200);\r",
                  "});\r",
                  "\r",
                  "pm.test(\"Token is returned\", function () {\r",
                  "    pm.expect(response.token).to.exist;\r",
                  "});\r",
                  "\r",
                  "pm.test(\"Token is not empty\", function () {\r",
                  "    pm.expect(response.token).to.not.be.empty;\r",
                  "});\r",
                  "\r",
                  "pm.test(\"Response time is less than 1000 ms\", function () {\r",
                  "    pm.expect(pm.response.responseTime).to.be.below(1000);\r",
                  "});\r",
                  "\r",
                  "pm.environment.set(\"token\", response.token);"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\r\n    \"username\": \"{{username}}\",\r\n    \"password\": \"{{password}}\"\r\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{base_url}}/auth",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "auth"
              ]
            }
          },
          "response": []
        }
      ]
    },
    {
      "name": "Booking",
      "item": [
        {
          "name": "Create Booking",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status code is 200\", function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "const response = pm.response.json();",
                  "",
                  "pm.test(\"Booking ID is returned\", function () {",
                  "    pm.expect(response.bookingid).to.exist;",
                  "});",
                  "",
                  "pm.test(\"Firstname is correct\", function () {",
                  "    pm.expect(response.booking.firstname).to.eql(\"John\");",
                  "});",
                  "",
                  "pm.test(\"Lastname is correct\", function () {",
                  "    pm.expect(response.booking.lastname).to.eql(\"Doe\");",
                  "});",
                  "",
                  "pm.test(\"Total price is correct\", function () {",
                  "    pm.expect(response.booking.totalprice).to.eql(120);",
                  "});",
                  "",
                  "pm.test(\"Deposit paid is correct\", function () {",
                  "    pm.expect(response.booking.depositpaid).to.be.true;",
                  "});",
                  "",
                  "pm.test(\"Check-in date is correct\", function () {",
                  "    pm.expect(response.booking.bookingdates.checkin).to.eql(\"2025-07-15\");",
                  "});",
                  "",
                  "pm.test(\"Check-out date is correct\", function () {",
                  "    pm.expect(response.booking.bookingdates.checkout).to.eql(\"2025-07-20\");",
                  "});",
                  "",
                  "pm.test(\"Additional needs is correct\", function () {",
                  "    pm.expect(response.booking.additionalneeds).to.eql(\"Breakfast\");",
                  "});"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\r\n    \"firstname\": \"John\",\r\n    \"lastname\": \"Doe\",\r\n    \"totalprice\": 120,\r\n    \"depositpaid\": true,\r\n    \"bookingdates\": {\r\n        \"checkin\": \"2025-07-15\",\r\n        \"checkout\": \"2025-07-20\"\r\n    },\r\n    \"additionalneeds\": \"Breakfast\"\r\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{base_url}}/booking",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "booking"
              ]
            }
          },
          "response": []
        }
      ]
    },
